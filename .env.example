# Copy to `.env` for local development (Mini Oxygen / Hydrogen CLI).
# Values from Shopify Admin → Headless or Hydrogen channel, or `shopify hydrogen env pull`.

SESSION_SECRET="replace-with-long-random-string"

PUBLIC_STOREFRONT_API_TOKEN=""
PUBLIC_STORE_DOMAIN="your-store.myshopify.com"
PUBLIC_STOREFRONT_ID=""
PUBLIC_CHECKOUT_DOMAIN="your-store.myshopify.com"

# Customer Account API (optional — only if you enable /account routes)
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=""
PUBLIC_CUSTOMER_ACCOUNT_API_URL=""

# Analytics placeholders (optional)
PUBLIC_GA4_MEASUREMENT_ID=""
PUBLIC_META_PIXEL_ID=""
PUBLIC_TIKTOK_PIXEL_ID=""

# Featured product handle (must exist in your Shopify admin)
PUBLIC_FEATURED_PRODUCT_HANDLE="aquaglow-filter-shower-head"

# UI language: set via header (English / Español / Deutsch). Storefront uses country US → USD.
